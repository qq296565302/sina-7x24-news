# Auto-detect text files
* text=auto

# Python / shell: LF (Unix convention, also fine on Windows)
*.py text eol=lf
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts: CRLF (preserve Windows semantics)
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Markdown / docs: LF (consistency on GitHub)
*.md text eol=lf
*.txt text eol=lf

# Config files
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Binary (skip eol conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.jsonl.gz binary
